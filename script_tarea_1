document.getElementById("form-actividades").addEventListener("submit", function(event) {
    event.preventDefault();

    let valido = true;

    const rut = document.getElementById("RUT").value.trim();
    const nombre = document.getElementById("nombre").value.trim();
    const apellido = document.getElementById("apellido").value.trim();
    const tipoPersona = document.getElementById("tipo_persona").value;
    const tipoActividad = document.getElementById("tipo_actividad").value;
    const horaInicio = document.getElementById("hora-inicio").value;
    const horaFin = document.getElementById("hora-fin").value;
    const media = document.getElementById("media").files[0];


 
    const rutRegex = /^[0-9]+-[0-9kK]$/;

    if (!rut || !rutRegex.test(rut)) {
      mostrarError("error-rut");
      valido = false;
    } else {
      ocultarError("error-rut");
    }

    if (nombre.length < 3) {
      mostrarError("error-nombre");
      valido = false;
    } else {
      ocultarError("error-nombre");
    }

    if (apellido.length < 3) {
      mostrarError("error-apellido");
      valido = false;
    } else {
      ocultarError("error-apellido");
    }

    if (!tipoPersona) {
      mostrarError("error-tipo_persona");
      valido = false;
    } else {
      ocultarError("error-tipo_persona");
    }


    if (!tipoActividad) {
      mostrarError("error-tipo_actividad");
      valido = false;
    } else {
      ocultarError("error-tipo_actividad");
    }


    if (!horaInicio) {
      mostrarError("error-inicio_hora");
      valido = false;
    } else {
      ocultarError("error-inicio_hora");
    }

    if (!horaFin || horaFin <= horaInicio) {
      mostrarError("error-fin_hora");
      valido = false;
    } else {
      ocultarError("error-fin_");
    }

    if (media) {
        if (media.type.startsWith(tipo) === "image/*" || media.type.startsWith(tipo) === "video/*" ){
            const esValido = true;
        } else {
            const esValido = false;
        }
        if (!esValido) {
            alert("El archivo debe ser imagen o video.");
            valido = false;
        }
    }

    if (valido) {
      alert("Actividad agregada correctamente ✅");
      form.reset();
    }

  function mostrarError(id) {
    document.getElementById(id).classList.add("visible");
  }

  function ocultarError(id) {
    document.getElementById(id).classList.remove("visible");
  }                                         
});